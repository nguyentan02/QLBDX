generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement()) @map("Id")
  username     String    @unique @map("Username") @db.NVarChar(50)
  passwordHash String    @map("PasswordHash") @db.NVarChar(255)
  fullName     String    @map("FullName") @db.NVarChar(100)
  email        String?   @map("Email") @db.NVarChar(100)
  phone        String?   @map("Phone") @db.NVarChar(20)
  role         String    @default("staff") @map("Role") @db.NVarChar(20)
  isActive     Boolean   @default(true) @map("IsActive")
  createdAt    DateTime  @default(now()) @map("CreatedAt")
  updatedAt    DateTime  @default(now()) @updatedAt @map("UpdatedAt")

  parkingRecords ParkingRecord[] @relation("CreatedByUser")
  payments       Payment[]       @relation("PaymentCreatedBy")

  @@map("Users")
}

model Customer {
  id           Int       @id @default(autoincrement()) @map("Id")
  fullName     String    @map("FullName") @db.NVarChar(100)
  phone        String    @map("Phone") @db.NVarChar(20)
  email        String?   @map("Email") @db.NVarChar(100)
  address      String?   @map("Address") @db.NVarChar(255)
  identityCard String?   @map("IdentityCard") @db.NVarChar(20)
  isActive     Boolean   @default(true) @map("IsActive")
  createdAt    DateTime  @default(now()) @map("CreatedAt")
  updatedAt    DateTime  @default(now()) @updatedAt @map("UpdatedAt")

  vehicles         Vehicle[]
  customerPackages CustomerPackage[]

  @@map("Customers")
}

model VehicleType {
  id          Int       @id @default(autoincrement()) @map("Id")
  name        String    @map("Name") @db.NVarChar(50)
  description String?   @map("Description") @db.NVarChar(200)
  hourlyRate  Decimal   @map("HourlyRate") @db.Decimal(10, 2)
  dailyRate   Decimal   @map("DailyRate") @db.Decimal(10, 2)
  monthlyRate Decimal   @map("MonthlyRate") @db.Decimal(10, 2)
  createdAt   DateTime  @default(now()) @map("CreatedAt")

  vehicles        Vehicle[]
  parkingPackages ParkingPackage[]
  parkingRecords  ParkingRecord[]

  @@map("VehicleTypes")
}

model Vehicle {
  id            Int       @id @default(autoincrement()) @map("Id")
  customerId    Int       @map("CustomerId")
  vehicleTypeId Int       @map("VehicleTypeId")
  licensePlate  String    @unique @map("LicensePlate") @db.NVarChar(20)
  brand         String?   @map("Brand") @db.NVarChar(50)
  model         String?   @map("Model") @db.NVarChar(50)
  color         String?   @map("Color") @db.NVarChar(30)
  createdAt     DateTime  @default(now()) @map("CreatedAt")
  updatedAt     DateTime  @default(now()) @updatedAt @map("UpdatedAt")

  customer        Customer          @relation(fields: [customerId], references: [id])
  vehicleType     VehicleType       @relation(fields: [vehicleTypeId], references: [id])
  parkingRecords  ParkingRecord[]
  customerPackages CustomerPackage[]

  @@map("Vehicles")
}

model ParkingZone {
  id          Int       @id @default(autoincrement()) @map("Id")
  name        String    @map("Name") @db.NVarChar(50)
  description String?   @map("Description") @db.NVarChar(200)
  totalSpots  Int       @default(0) @map("TotalSpots")
  createdAt   DateTime  @default(now()) @map("CreatedAt")

  parkingSpots ParkingSpot[]

  @@map("ParkingZones")
}

model ParkingSpot {
  id         Int       @id @default(autoincrement()) @map("Id")
  zoneId     Int       @map("ZoneId")
  spotNumber String    @map("SpotNumber") @db.NVarChar(10)
  spotType   String    @default("standard") @map("SpotType") @db.NVarChar(20)
  status     String    @default("available") @map("Status") @db.NVarChar(20)
  createdAt  DateTime  @default(now()) @map("CreatedAt")

  zone           ParkingZone     @relation(fields: [zoneId], references: [id])
  parkingRecords ParkingRecord[]

  @@unique([zoneId, spotNumber])
  @@map("ParkingSpots")
}

model ParkingPackage {
  id            Int       @id @default(autoincrement()) @map("Id")
  name          String    @map("Name") @db.NVarChar(100)
  vehicleTypeId Int       @map("VehicleTypeId")
  durationDays  Int       @map("DurationDays")
  price         Decimal   @map("Price") @db.Decimal(10, 2)
  description   String?   @map("Description") @db.NVarChar(500)
  isActive      Boolean   @default(true) @map("IsActive")
  createdAt     DateTime  @default(now()) @map("CreatedAt")

  vehicleType      VehicleType       @relation(fields: [vehicleTypeId], references: [id])
  customerPackages CustomerPackage[]

  @@map("ParkingPackages")
}

model CustomerPackage {
  id         Int       @id @default(autoincrement()) @map("Id")
  customerId Int       @map("CustomerId")
  packageId  Int       @map("PackageId")
  vehicleId  Int       @map("VehicleId")
  startDate  DateTime  @map("StartDate") @db.Date
  endDate    DateTime  @map("EndDate") @db.Date
  status     String    @default("active") @map("Status") @db.NVarChar(20)
  createdAt  DateTime  @default(now()) @map("CreatedAt")

  customer       Customer       @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parkingPackage ParkingPackage @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle        Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments       Payment[]      @relation("PackagePayment")

  @@map("CustomerPackages")
}

model ParkingRecord {
  id            Int       @id @default(autoincrement()) @map("Id")
  vehicleId     Int?      @map("VehicleId")
  licensePlate  String    @map("LicensePlate") @db.NVarChar(20)
  vehicleTypeId Int       @map("VehicleTypeId")
  parkingSpotId Int?      @map("ParkingSpotId")
  entryTime     DateTime  @default(now()) @map("EntryTime")
  exitTime      DateTime? @map("ExitTime")
  duration      Int?      @map("Duration")
  fee           Decimal?  @map("Fee") @db.Decimal(10, 2)
  status        String    @default("parked") @map("Status") @db.NVarChar(20)
  notes         String?   @map("Notes") @db.NVarChar(500)
  createdBy     Int?      @map("CreatedBy")
  createdAt     DateTime  @default(now()) @map("CreatedAt")

  vehicle     Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicleType VehicleType  @relation(fields: [vehicleTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parkingSpot ParkingSpot? @relation(fields: [parkingSpotId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator     User?        @relation("CreatedByUser", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments    Payment[]    @relation("ParkingPayment")

  @@map("ParkingRecords")
}

model Payment {
  id                Int       @id @default(autoincrement()) @map("Id")
  parkingRecordId   Int?      @map("ParkingRecordId")
  customerPackageId Int?      @map("CustomerPackageId")
  amount            Decimal   @map("Amount") @db.Decimal(10, 2)
  paymentMethod     String    @default("cash") @map("PaymentMethod") @db.NVarChar(30)
  paymentType       String    @default("parking") @map("PaymentType") @db.NVarChar(30)
  status            String    @default("completed") @map("Status") @db.NVarChar(20)
  paidAt            DateTime  @default(now()) @map("PaidAt")
  createdBy         Int?      @map("CreatedBy")
  notes             String?   @map("Notes") @db.NVarChar(500)

  parkingRecord   ParkingRecord?   @relation("ParkingPayment", fields: [parkingRecordId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerPackage CustomerPackage? @relation("PackagePayment", fields: [customerPackageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator         User?            @relation("PaymentCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("Payments")
}
